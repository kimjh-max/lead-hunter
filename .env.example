# Lead Hunter 환경 설정
# 이 파일을 .env로 복사 후 값을 채워주세요

# 이메일 설정 (Gmail 앱 비밀번호 사용 권장)
LH_SMTP_HOST=smtp.gmail.com
LH_SMTP_PORT=587
LH_SMTP_USER=your-email@gmail.com
LH_SMTP_PASSWORD=your-app-password
LH_SENDER_NAME=EpicStage
LH_SENDER_EMAIL=your-email@gmail.com

# 발송 제한
LH_MAX_EMAILS_PER_HOUR=20
LH_MAX_EMAILS_PER_DAY=100
LH_EMAIL_INTERVAL_SECONDS=30

# 크롤링 설정
LH_CRAWL_INTERVAL_HOURS=24
LH_REQUEST_DELAY_SECONDS=2.0

# 디버그 모드
LH_DEBUG=false
